# HealthMax — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# ---------------------------------------------------------------------------
# LLM APIs
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
BEDROCK_REGION=us-east-1

# ---------------------------------------------------------------------------
# Twilio (WhatsApp / SMS)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ---------------------------------------------------------------------------
# Google Cloud TTS
# ---------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/home/ubuntu/healthmax/gcp-key.json

# ---------------------------------------------------------------------------
# Model paths (override defaults if storing on S3-synced mount)
# ---------------------------------------------------------------------------
NER_MODEL_PATH=sagorsarker/bangla-bert-base
CLASSIFIER_MODEL_PATH=./models/disease_classifier.json
BINARIZER_PATH=./models/symptom_binarizer.json
LABEL_ENCODER_PATH=./models/disease_label_encoder.json
FAISS_INDEX_PATH=./models/disease_rag.index
DISEASE_RECORDS_PATH=./models/disease_records.json
DGDA_CSV_PATH=./data/dgda_medicines_clean.csv

# ---------------------------------------------------------------------------
# AWS (for S3 dataset access and Bedrock)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=healthmax-datasets
